# Required
JWT_SECRET=your-secret-here

# Server
PORT=3001
NODE_ENV=production
CORS_ORIGIN=http://localhost:3001

# Database (pick one)
# Option 1: SQLite (default, good for development and small deployments)
DB_PATH=./data/hiveops.db

# Option 2: PostgreSQL (recommended for production)
# DATABASE_URL=postgres://user:password@localhost:5432/hiveops

# AI / LLM (any OpenAI-compatible API)
# Leave blank to use simulated agent responses
LLM_API_URL=
LLM_API_KEY=
DEFAULT_MODEL=gpt-4

# SMTP (outbound email - configure for production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# IMAP (inbound email - configure for production)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# Logging
LOG_LEVEL=info

# Docker / PostgreSQL (only needed if using PostgreSQL)
POSTGRES_USER=hiveops
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hiveops

# ============================================
# SECURITY NOTES
# ============================================
# 1. Generate a strong JWT_SECRET: openssl rand -base64 32
# 2. Never commit .env to version control
# 3. Use PostgreSQL for production deployments
# 4. Use strong passwords for all services
# 5. Keep LLM_API_KEY secure — it has billing implications
