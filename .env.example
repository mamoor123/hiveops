# ═══════════════════════════════════════
# Company OS - Environment Configuration
# ═══════════════════════════════════════
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.

# ── Server ──
PORT=3001
NODE_ENV=development

# ── Auth (REQUIRED) ──
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-here

# ── CORS ──
CORS_ORIGIN=http://localhost:3000

# ── Database ──
DB_PATH=./data/company-os.db

# ── LLM / AI Engine ──
# Set these to enable real AI agent responses.
# Works with any OpenAI-compatible API.
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=
DEFAULT_MODEL=gpt-4

# ── SMTP (Outbound Email) ──
# Configure to send real emails. Without these, email is stored in DB only.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# ── IMAP (Inbound Email) ──
# Configure to poll for incoming emails. Optional.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your-email@gmail.com
IMAP_PASS=your-app-password
IMAP_POLL_INTERVAL_MS=60000

# ── Frontend ──
# (set in web/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:3001
